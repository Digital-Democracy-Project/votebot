# VoteBot Environment Configuration
# Copy this file to .env and fill in your values

# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
API_KEY=your-api-key-here

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=votebot
PINECONE_NAMESPACE=default

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (optional)
DATABASE_URL=postgresql://votebot:password@localhost:5432/votebot

# External APIs
CONGRESS_API_KEY=your-congress-api-key
OPENSTATES_API_KEY=your-openstates-api-key

# RAG Configuration
CHUNK_SIZE=750
CHUNK_OVERLAP=150
MAX_RETRIEVAL_CHUNKS=10
SIMILARITY_THRESHOLD=0.7

# Performance
REQUEST_TIMEOUT_SECONDS=30
MAX_CONCURRENT_REQUESTS=1000

# AWS (for production deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
