# VoteBot Environment Configuration
# Copy this file to .env and fill in your values

# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
API_KEY=your-api-key-here

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Web Search (Responses API)
WEB_SEARCH_ENABLED=true
WEB_SEARCH_CONTEXT_SIZE=medium
WEB_SEARCH_ON_LOW_CONFIDENCE=true
WEB_SEARCH_CONFIDENCE_THRESHOLD=0.5

# Pinecone
PINECONE_API_KEY=your-pinecone-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=votebot
PINECONE_NAMESPACE=default

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (optional)
DATABASE_URL=postgresql://votebot:password@localhost:5432/votebot

# External APIs
CONGRESS_API_KEY=your-congress-api-key
OPENSTATES_API_KEY=your-openstates-api-key

# Webflow CMS
WEBFLOW_VOTEBOT_API_KEY=your-webflow-read-only-api-key
WEBFLOW_SCHEDULER_API_KEY=your-webflow-read-write-api-key
WEBFLOW_SITE_ID=your-webflow-site-id
WEBFLOW_BILLS_COLLECTION_ID=your-bills-collection-id
WEBFLOW_JURISDICTION_COLLECTION_ID=your-jurisdiction-collection-id
WEBFLOW_LEGISLATORS_COLLECTION_ID=your-legislators-collection-id
WEBFLOW_CATEGORIES_COLLECTION_ID=your-categories-collection-id
WEBFLOW_ORGANIZATIONS_COLLECTION_ID=your-organizations-collection-id

# RAG Configuration
CHUNK_SIZE=750
CHUNK_OVERLAP=150
MAX_RETRIEVAL_CHUNKS=10
SIMILARITY_THRESHOLD=0.1

# Performance
REQUEST_TIMEOUT_SECONDS=30
MAX_CONCURRENT_REQUESTS=1000

# AWS (for production deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Slack Integration (for human handoff)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SUPPORT_CHANNEL=#votebot-support
